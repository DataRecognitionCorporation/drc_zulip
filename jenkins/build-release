#!/usr/bin/env groovy

@Library('DRC_Global_Pipeline_Libraries@master')

def has_failures = false

pipeline {
    agent {
        kubernetes {
            yamlFile 'jenkins/k8s/zulip_ci_jammy.yaml'
        }
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '100', artifactNumToKeepStr: '100'))
        ansiColor('xterm')
    }

    environment {
        GITHUB_ACTIONS = true
        VIRTUAL_ENV = "/srv/zulip-py3-venv"
    }

    stages {
         stage('Configure') {
            steps {
                container('zulip-ci-jammy') {
                    dir("${WORKSPACE}"){
                        script {
                            sh """#!/bin/bash
                                set -euo xtrace
                                git config zulip.zulipRemote origin

                                ./tools/provision --build-release-tarball-only
                            """
                        }
                    }
                }
            }
        }
        stage('Build') {
            steps {
                container('zulip-ci-jammy') {
                    dir("${WORKSPACE}"){
                        script {
                            sh """#!/bin/bash
                                set -eu
                                git config zulip.zulipRemote origin

                                source ./tools/ci/activate-venv

                                ./tools/build-release-tarball ${env.TAG_NAME} \
                                    && mv /tmp/tmp.*/*-${env.TAG_NAME}.tar.gz ./
                            """
                        }
                    }
                }
            }
        }
        stage('Deploy') {
            steps {
                container('zulip-ci-jammy') {
                    dir("${WORKSPACE}"){
                        script {
                            uploadToArtifactory([
                                repo: 'downloads',
                                pattern: "./*-${env.TAG_NAME}.tar.gz",
                                git_proj: 'zulip',
                                arti_url: 'https://artifactory.datarecognitioncorp.com/artifactory',
                                isYumRepo: false
                            ])
                        }
                    }
                }
            }
        }
    }
}
